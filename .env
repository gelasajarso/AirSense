# AirSense Environment Configuration
# Copy this file to .env and update values as needed

# Application Settings
APP_NAME=AirSense
APP_VERSION=1.0.0
DEBUG=false

# Data Paths
DATA_DIR=data
RAW_DATA_DIR=data/raw
PROCESSED_DATA_DIR=data/processed
MODELS_DIR=models
LOGS_DIR=logs

# Spark Configuration
SPARK_APP_NAME=AirSense
SPARK_MASTER=local[*]
SPARK_EXECUTOR_MEMORY=4g
SPARK_DRIVER_MEMORY=2g
SPARK_EXECUTOR_CORES=2

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=1
API_RELOAD=false

# Database (Future)
# DATABASE_URL=postgresql://user:password@localhost:5432/airsense

# ML Configuration
DEFAULT_FORECAST_STEPS=24
MODEL_RETRAIN_INTERVAL=24

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=%(asctime)s - %(name)s - %(levelname)s - %(message)s

# Monitoring
ENABLE_METRICS=true
METRICS_PORT=9090

# Security
SECRET_KEY=your-secret-key-change-this-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Redis Configuration (Optional)
REDIS_URL=redis://localhost:6379/0

# External APIs (Optional)
# OPENWEATHER_API_KEY=your-openweather-api-key
# AIR_QUALITY_API_KEY=your-air-quality-api-key
